+    private Vector3 GetEntrancePassWorldPosition()
+    {
+        if (gridManager != null && gridManager.TryGetEntranceWalkWorldPosition(GetEntranceCustomerRadius(), out Vector3 entranceWalk))
+        {
+            return entranceWalk;
+        }
+
+        Vector3 entranceBase = GetEntranceBaseWorldPosition();
+        return new Vector3(
+            entranceBase.x + (GetSafeCellSize() * FallbackEntranceWalkWaypointOffsetCells),
+            entranceBase.y,
+            0f);
+    }
+
+    private Vector3 GetEntranceInsideWorldPosition()
+    {
+        if (gridManager != null && gridManager.TryGetEntranceInsideSafeWorldPosition(GetEntranceCustomerRadius(), out Vector3 entranceInside))
+        {
+            return entranceInside;
+        }
+
+        Vector3 entranceBase = GetEntranceBaseWorldPosition();
+        return new Vector3(
+            entranceBase.x + (GetSafeCellSize() * FallbackEntranceInsideSafeWaypointOffsetCells),
+            entranceBase.y,
+            0f);
+    }
+
+    private Vector3 GetEntryWorldPosition()
+    {
+        if (gridManager != null && gridManager.TryGetEntranceOutsideWorldPosition(GetEntranceCustomerRadius(), out Vector3 entranceOutside))
+        {
+            return entranceOutside;
+        }
+
+        Vector3 entranceBase = GetEntranceBaseWorldPosition();
