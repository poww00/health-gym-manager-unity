+        customer.layeredExitFadeOutStarted = false;
+        customer.layeredExitFadeOutCompleted = false;
+        customer.layeredExitRouteCompletionBlockedLogged = false;
+        customer.layeredExitFadeOutElapsed = 0f;
+        customer.exitStartedPosition = customer.worldPosition;
+        customer.hasExitStartedPosition = true;
+        customer.layeredExitStartedTime = Time.time;
+        customer.exitStartedToDeskDistance = customer.hasReceptionOrDeskPoint
+            ? GetPlanarDistance(customer.exitStartedPosition, customer.receptionOrDeskPoint)
+            : -1f;
+        customer.exitFadeOutStartedPosition = Vector3.zero;
+        customer.exitFadeOutStartToHideDistance = -1f;
+        customer.exitHiddenToDeskDistance = -1f;
+        customer.exitHideDistanceAtHidden = -1f;
+        ApplyLayeredCustomerVisualScale(customer);
+        SetLayeredCustomerVisible(customer, true, "exit started, keep layered customer visible");
