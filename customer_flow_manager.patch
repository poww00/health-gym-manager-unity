+        }
+
+        Vector3 target = customer.routeWaypoints[customer.routeWaypointIndex];
+        UpdateCustomerFacingDirection(customer, target);
+        float dist = Vector3.Distance(customer.worldPosition, target);
+        if (dist <= moveStep)
+        {
+            customer.worldPosition = target;
+            customer.routeWaypointIndex += 1;
+        }
+        else
+        {
+            customer.worldPosition = Vector3.MoveTowards(customer.worldPosition, target, moveStep);
+        }
+
+        if (customer.visual != null)
+        {
+            customer.visual.transform.position = customer.worldPosition;
+        }
+
+        UpdateLayeredCustomerEntranceReveal(customer);
+        UpdateLayeredCustomerExitHide(customer);
+        return customer.routeWaypointIndex >= customer.routeWaypoints.Count;
+    }
+
+    private void SetCustomerRoute(ActiveCustomer customer, List<Vector3> waypoints)
+    {
+        if (customer == null)
+        {
+            return;
+        }
+
+        customer.routeWaypoints.Clear();
+        customer.routeWaypointIndex = 0;
+
+        if (waypoints == null)
+        {
+            return;
+        }
+
+        for (int i = 0; i < waypoints.Count; i++)
+        {
+            AddWaypointIfDistinct(customer.routeWaypoints, waypoints[i]);
+        }
+    }
+
+    private List<Vector3> BuildCustomerRoute(
+        Vector3 startWorld,
+        Vector3 destinationWorld,
+        bool enterThroughEntrance,
+        bool useLayeredSafeRevealPoint = false)
+    {
+        List<Vector3> route = new List<Vector3>();
+        Vector3 routeStart = startWorld;
+
+        // Temporary route gate: customers use explicit entrance waypoints until full navigation is shared.
+        if (enterThroughEntrance)
+        {
+            if (useLayeredSafeRevealPoint)
+            {
+                GetLayeredCustomerEntrancePointInfo();
+            }
+
+            AddWaypointIfDistinct(route, GetEntryWorldPosition());
+            AddWaypointIfDistinct(route, GetEntrancePassWorldPosition());
+            Vector3 entranceInsideWorld = GetEntranceInsideWorldPosition();
+            routeStart = entranceInsideWorld;
+            AddWaypointIfDistinct(route, routeStart);
+        }
+
+        if (!AppendGridPathWaypoints(route, routeStart, destinationWorld))
+        {
+            AddWaypointIfDistinct(route, destinationWorld);
+        }
+
+        return route;
+    }
