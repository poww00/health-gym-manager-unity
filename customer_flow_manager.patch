+
+    private float GetLayeredCustomerEntranceFadeInSeconds()
+    {
+        float sharedFadeSeconds = GetLayeredCustomerFadeSeconds();
+        if (!layeredCustomerFadeDurationWarningLogged &&
+            Mathf.Abs(layeredCustomerEntranceFadeInSeconds - sharedFadeSeconds) > 0.001f)
+        {
+            layeredCustomerFadeDurationWarningLogged = true;
+            Debug.LogWarning(
+                "[CustomerFlowManager] Layered customer entry fade duration differed from exit fade duration; entry fade-in now uses the exit fade-out duration.\n" +
+                $"Serialized entry fade seconds: {layeredCustomerEntranceFadeInSeconds:0.###}\n" +
+                $"Exit fade-out seconds: {sharedFadeSeconds:0.###}\n" +
+                $"Effective entry fade-in seconds: {sharedFadeSeconds:0.###}");
+        }
+
+        return sharedFadeSeconds;
+    }
+
+    private static float EvaluateLayeredCustomerFade01(float elapsedSeconds, float durationSeconds)
+    {
+        return Mathf.Clamp01(Mathf.Max(0f, elapsedSeconds) / Mathf.Max(0.01f, durationSeconds));
+    }
+
+    private LayeredExitFadeDecision GetLayeredCustomerExitFadeDecision(ActiveCustomer customer)
+    {
+        return customer != null
+            ? GetLayeredCustomerExitFadeDecision(customer.worldPosition, customer.exitSafeHidePoint)
+            : default;
+    }
+
+    private LayeredExitFadeDecision GetLayeredCustomerExitFadeDecision(Vector3 customerPosition, Vector3 exitHidePoint)
+    {
+        float halfWidth = GetLayeredCustomerExitFadeZoneHalfWidth();
+        float halfHeight = GetLayeredCustomerExitFadeZoneHalfHeight();
+        float distance = GetPlanarDistance(customerPosition, exitHidePoint);
+        bool insideZone =
+            Mathf.Abs(customerPosition.x - exitHidePoint.x) <= halfWidth &&
+            Mathf.Abs(customerPosition.y - exitHidePoint.y) <= halfHeight;
+        bool withinFadeDistance = distance <= GetLayeredCustomerExitFadeDistanceWorld();
+        bool leftThreshold = customerPosition.x <= exitHidePoint.x + GetLayeredCustomerExitFadeStartInsetWorld();
+        bool hardCutoff = customerPosition.x < exitHidePoint.x - GetLayeredCustomerExitHardCutoffOffsetWorld();
+
+        string reason = "none";
+        if (hardCutoff)
+        {
+            reason = "hard-cutoff";
+        }
+        else if (insideZone)
+        {
+            reason = "zone";
+        }
+        else if (withinFadeDistance)
+        {
+            reason = "distance";
+        }
+        else if (leftThreshold)
+        {
+            reason = "left-threshold";
+        }
+
+        return new LayeredExitFadeDecision
+        {
+            distanceToExitHidePoint = distance,
+            insideExitFadeZone = insideZone,
+            withinFadeDistance = withinFadeDistance,
+            passedLeftEntranceThreshold = leftThreshold,
+            passedHardCutoff = hardCutoff,
+            shouldStartFadeOut = insideZone || withinFadeDistance || leftThreshold,
+            reason = reason
+        };
+    }
+
+    private void WarnIfLayeredCustomerRevealTransitionLooksWrong(ActiveCustomer customer, float revealDistance)
+    {
+        if (customer == null)
+        {
+            return;
+        }
+
+        float revealRadius = GetLayeredCustomerEntranceRevealRadius();
+        if (revealDistance > revealRadius + 0.05f)
+        {
+            Debug.LogWarning(
+                "[CustomerFlowManager] Layered customer became visible too far from the entrance reveal marker.\n" +
+                $"Customer root position: {FormatVector3(customer.worldPosition)}\n" +
+                $"Final reveal point: {FormatVector3(customer.entranceSafeRevealPoint)}\n" +
+                $"Root-to-marker distance: {revealDistance:0.###}\n" +
+                $"Reveal radius: {revealRadius:0.###}");
+        }
+
+        if (customer.hasReceptionOrDeskPoint &&
+            Vector3.Distance(customer.worldPosition, customer.receptionOrDeskPoint) <= 0.5f)
+        {
+            Debug.LogWarning(
+                "[CustomerFlowManager] Layered customer became visible near the reception/desk point; reveal should happen at the entrance marker.\n" +
+                $"Customer root position: {FormatVector3(customer.worldPosition)}\n" +
+                $"Reception/desk point: {FormatVector3(customer.receptionOrDeskPoint)}");
+        }
+    }
+
+    private void WarnIfLayeredCustomerExitTransitionLooksWrong(ActiveCustomer customer, float hideDistance)
+    {
+        if (customer == null)
+        {
+            return;
+        }
+
+        float hideRadius = GetLayeredCustomerExitHideRadius();
+        LayeredExitFadeDecision disabledDecision = GetLayeredCustomerExitFadeDecision(
+            customer.exitHiddenTransitionPosition,
+            customer.exitSafeHidePoint);
+        if (hideDistance >= 0.3f &&
+            !disabledDecision.insideExitFadeZone &&
+            !disabledDecision.passedHardCutoff)
+        {
+            Debug.LogWarning(
+                "[CustomerFlowManager] Layered customer was hidden too far from the entrance hide marker.\n" +
+                $"Customer root position: {FormatVector3(customer.worldPosition)}\n" +
+                $"Final hide point: {FormatVector3(customer.exitSafeHidePoint)}\n" +
+                $"Root-to-marker distance: {hideDistance:0.###}\n" +
+                $"Hide radius: {hideRadius:0.###}\n" +
+                $"Inside exit fade zone: {disabledDecision.insideExitFadeZone}\n" +
+                $"Hard cutoff: {disabledDecision.passedHardCutoff}");
+        }
+
+        if (customer.hasReceptionOrDeskPoint)
+        {
+            float deskDistance = customer.exitHiddenToDeskDistance >= 0f
+                ? customer.exitHiddenToDeskDistance
+                : GetPlanarDistance(customer.worldPosition, customer.receptionOrDeskPoint);
+            if (deskDistance < hideDistance)
+            {
+                Debug.LogWarning(
+                    "[CustomerFlowManager] Layered customer was hidden closer to the reception/desk point than the exit hide point.\n" +
+                    $"Disabled customer position: {FormatVector3(customer.worldPosition)}\n" +
+                    $"Final exit hide point: {FormatVector3(customer.exitSafeHidePoint)}\n" +
+                    $"Reception/desk point: {FormatVector3(customer.receptionOrDeskPoint)}\n" +
+                    $"Disabled-to-hide distance: {hideDistance:0.###}\n" +
+                    $"Disabled-to-desk distance: {deskDistance:0.###}");
+            }
+        }
+
+        bool hiddenImmediatelyByTime = customer.layeredExitStartedTime >= 0f &&
+            Time.time - customer.layeredExitStartedTime <= 0.15f;
+        bool hiddenImmediatelyByDistance = customer.hasExitStartedPosition &&
+            GetPlanarDistance(customer.exitStartedPosition, customer.exitHiddenTransitionPosition) <= 0.05f;
+        if (hiddenImmediatelyByTime || hiddenImmediatelyByDistance)
+        {
+            Debug.LogWarning(
+                "[CustomerFlowManager] Layered customer was hidden immediately after exit started. Hide should wait until the entrance marker is reached.\n" +
+                $"Exit started position: {FormatVector3(customer.exitStartedPosition)}\n" +
+                $"Disabled customer position: {FormatVector3(customer.exitHiddenTransitionPosition)}\n" +
+                $"Elapsed since exit start: {(customer.layeredExitStartedTime >= 0f ? Time.time - customer.layeredExitStartedTime : -1f):0.###}s");
+        }
+    }
+
+    private void StartLayeredCustomerEntranceFadeIn(ActiveCustomer customer)
+    {
+        if (customer == null || !customer.usesLayeredCustomerSprites)
+        {
+            return;
+        }
+
+        ApplyLayeredCustomerVisualScale(customer);
+        SetLayeredCustomerVisible(customer, true, "entrance fade-in started");
+        float fadeSeconds = GetLayeredCustomerEntranceFadeInSeconds();
+        if (fadeSeconds <= 0.01f)
+        {
+            customer.layeredEntranceFadeInActive = false;
+            customer.layeredEntranceFadeInElapsed = 0f;
+            SetLayeredCustomerRenderersAlpha(customer, 1f);
+            LogLayeredCustomerEntranceFadeInCompleted(customer);
+            return;
+        }
+
+        customer.layeredEntranceFadeInActive = true;
+        customer.layeredEntranceFadeInElapsed = 0f;
+        SetLayeredCustomerRenderersAlpha(customer, 0f);
+        WarnIfLayeredCustomerBodyHeadAlphaMismatch(customer, "entry fade-in started");
+        Debug.Log(
+            "[CustomerFlowManager] Layered customer entrance fade-in started\n" +
+            $"Layered customer fade seconds: {GetLayeredCustomerFadeSeconds():0.###}\n" +
+            $"Fade-in seconds: {fadeSeconds:0.###}\n" +
+            $"Exit fade-out seconds: {GetLayeredCustomerExitFadeOutSeconds():0.###}\n" +
+            $"Entry fade-in start alpha: 0\n" +
+            $"Entry fade-in end alpha: 1\n" +
+            $"Body/Head alpha same: {AreLayeredCustomerBodyHeadAlphasEqual(customer)}\n" +
+            $"Current visual root scale: {FormatVector3(customer.visual != null ? customer.visual.transform.localScale : Vector3.zero)}\n" +
+            $"HeadLocalOffset: {FormatVector3(layeredCustomerHeadLocalOffset)}");
+    }
+
+    private void UpdateLayeredCustomerEntranceFade(ActiveCustomer customer, float deltaTime)
+    {
+        if (customer == null || !customer.usesLayeredCustomerSprites || !customer.layeredEntranceFadeInActive)
+        {
+            return;
+        }
+
+        float fadeSeconds = GetLayeredCustomerEntranceFadeInSeconds();
+        customer.layeredEntranceFadeInElapsed += Mathf.Max(0f, deltaTime);
+        float alpha = EvaluateLayeredCustomerFade01(customer.layeredEntranceFadeInElapsed, fadeSeconds);
+        SetLayeredCustomerRenderersAlpha(customer, alpha);
+        WarnIfLayeredCustomerBodyHeadAlphaMismatch(customer, "entry fade-in update");
+
+        if (alpha >= 1f)
+        {
+            customer.layeredEntranceFadeInActive = false;
+            customer.layeredEntranceFadeInCompletedTime = Time.time;
+            SetLayeredCustomerRenderersAlpha(customer, 1f);
+            WarnIfLayeredCustomerBodyHeadAlphaMismatch(customer, "entry fade-in completed");
+            LogLayeredCustomerEntranceFadeInCompleted(customer);
+        }
+    }
