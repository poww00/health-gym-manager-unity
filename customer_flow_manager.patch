+    private Vector3 GetExitWorldPosition()
+    {
+        return GetCustomerSpawnWorldPosition();
+    }
+
+    private Vector3 GetCustomerSpawnWorldPosition()
+    {
+        Vector3 entranceOutside = GetEntryWorldPosition();
+        return new Vector3(
+            entranceOutside.x - Mathf.Max(0.8f, entryExitOffsetX),
+            entranceOutside.y,
+            0f);
+    }
+
+    private Vector3 GetEntranceBaseWorldPosition()
+    {
+        if (gridManager != null && gridManager.TryGetDefaultEntrancePassWorldPosition(out Vector3 entrancePass))
+        {
+            return entrancePass;
+        }
+
+        if (gridManager == null)
+        {
+            return Vector3.zero;
+        }
+
+        float halfWidth = gridManager.Width * gridManager.CellSize * 0.5f;
+        float halfHeight = gridManager.Height * gridManager.CellSize * 0.5f;
+        return new Vector3(
+            -halfWidth + (gridManager.CellSize * 0.5f),
+            -halfHeight + (gridManager.Height * gridManager.CellSize * Mathf.Clamp01(entryExitHeightRatio)),
+            0f);
+    }
+
+    private float GetSafeCellSize()
+    {
+        return gridManager != null ? Mathf.Max(0.01f, gridManager.CellSize) : 1f;
+    }
+
+    private float GetEntranceCustomerRadius()
+    {
+        float visualRadius = Mathf.Max(customerVisualSize.x, customerVisualSize.y) * 0.5f;
+        return Mathf.Max(visualRadius, GetSafeCellSize() * 0.20f);
     }
 
