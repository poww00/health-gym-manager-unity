+    private void UpdateLayeredCustomerBodyFrame(ActiveCustomer customer)
+    {
+        if (customer == null || !customer.usesLayeredCustomerSprites || customer.bodyRenderer == null)
+        {
+            return;
+        }
+
+        ApplyLayeredCustomerVisualScale(customer);
+        
+        bool isMoving = customer.state == CustomerState.MovingToMachine || customer.state == CustomerState.Leaving || (customer.state == CustomerState.WaitingForMachine && customer.waitSlotIndex >= 0 && (customer.visual.transform.position - GetWaitingWorldPosition(customer.waitSlotIndex)).sqrMagnitude > 0.001f);
+        
+        Sprite[] walkFrames = customer.isWalkingVertical ? GetLayeredCustomerBodyWalkVerticalFrames() : GetLayeredCustomerBodyWalkFrames();
+        Sprite[] idleFrames = GetLayeredCustomerBodyIdleFrames();
+        
+        float fps = Mathf.Clamp(layeredCustomerBodyIdleFps, 1f, 12f);
+        float walkFps = fps * 1.5f;
+
+        if (isMoving && !customer.wasMoving)
+        {
+            customer.walkPhase = 1; // Start
+            customer.walkPhaseTimer = 0f;
+        }
+        else if (!isMoving && customer.wasMoving)
+        {
+            customer.walkPhase = 3; // Stop
+            customer.walkPhaseTimer = 0f;
+        }
+        
+        customer.wasMoving = isMoving;
+
+        Sprite currentSprite = null;
+
+        if (walkFrames != null && walkFrames.Length == 4)
+        {
+            if (isMoving)
+            {
+                customer.walkPhaseTimer += Time.deltaTime;
+                int frameIndex = Mathf.FloorToInt(customer.walkPhaseTimer * walkFps) % 4;
+                currentSprite = walkFrames[frameIndex];
+            }
+            else
+            {
+                customer.walkPhaseTimer = 0f;
+                customer.walkPhase = 0;
+            }
+        }
+        else
+        {
+            if (customer.walkPhase == 0) // Idle
+            {
+                int frameCount = idleFrames != null ? idleFrames.Length : 0;
+                if (frameCount > 0)
+                {
+                    int frameIndex = Mathf.FloorToInt((Time.time + customer.bodyIdleAnimationOffsetSeconds) * fps) % frameCount;
+                    currentSprite = idleFrames[frameIndex];
+                }
+            }
+            else if (customer.walkPhase == 1) // Start (Frames 0, 1)
+            {
+                customer.walkPhaseTimer += Time.deltaTime;
+                int frameCount = 2; // 0 and 1
+                int frameIndex = Mathf.FloorToInt(customer.walkPhaseTimer * walkFps);
+                if (frameIndex >= frameCount)
+                {
+                    customer.walkPhase = 2; // Transition to walk
+                    customer.walkPhaseTimer = 0f; // Reset for walk
+                }
+                if (walkFrames != null && walkFrames.Length >= 2 && customer.walkPhase == 1)
+                {
+                    currentSprite = walkFrames[frameIndex];
+                }
+            }
+            
+            if (customer.walkPhase == 2) // Walking (Frames 2, 3, 4, 5)
+            {
+                customer.walkPhaseTimer += Time.deltaTime;
+                int frameCount = 4;
+                int frameIndex = Mathf.FloorToInt(customer.walkPhaseTimer * walkFps) % frameCount;
+                if (walkFrames != null && walkFrames.Length >= 6)
+                {
+                    currentSprite = walkFrames[2 + frameIndex];
+                }
+            }
+            else if (customer.walkPhase == 3) // Stopping (Frames 6, 7)
+            {
+                customer.walkPhaseTimer += Time.deltaTime;
+                int frameCount = 2; // 6 and 7
+                int frameIndex = Mathf.FloorToInt(customer.walkPhaseTimer * walkFps);
+                if (frameIndex >= frameCount)
+                {
+                    customer.walkPhase = 0; // Transition to idle
+                    customer.walkPhaseTimer = 0f;
+                }
+                if (walkFrames != null && walkFrames.Length >= 8 && customer.walkPhase == 3)
+                {
+                    currentSprite = walkFrames[6 + frameIndex];
+                }
+            }
+        }
+        
+        // Fallback if missing
+        if (currentSprite == null && customer.walkPhase == 0 && idleFrames != null && idleFrames.Length > 0)
+        {
+            currentSprite = idleFrames[0];
+        }
+
+        if (currentSprite != null)
+        {
+            customer.bodyRenderer.sprite = currentSprite;
+        }
+    }
