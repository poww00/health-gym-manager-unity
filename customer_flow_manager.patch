+    private void UpdateCustomerFacingDirection(ActiveCustomer customer, Vector3 targetPosition)
+    {
+        if (customer == null) return;
+        
+        float deltaX = targetPosition.x - customer.worldPosition.x;
+        float deltaY = targetPosition.y - customer.worldPosition.y;
+        
+        // Determine primary movement direction for animation selection
+        // ONLY purely vertical movement (no significant X movement) uses vertical sprite
+        if (Mathf.Abs(deltaX) < 0.05f && Mathf.Abs(deltaY) >= 0.05f)
+        {
+            customer.isWalkingVertical = true;
+        }
+        else if (Mathf.Abs(deltaX) >= 0.05f)
+        {
+            customer.isWalkingVertical = false;
+        }
+
+        // Swap head sprite based on direction (expects 3 frames: Front, Side, Back)
+        Sprite[] headFrames = GetLayeredCustomerHeadFrames();
+        if (headFrames != null && headFrames.Length >= 3 && customer.headRenderer != null)
+        {
+            if (customer.isWalkingVertical)
+            {
+                if (deltaY > 0f) customer.headRenderer.sprite = headFrames[2]; // Back
+                else customer.headRenderer.sprite = headFrames[0]; // Front
+            }
+            else
+            {
+                customer.headRenderer.sprite = headFrames[1]; // Side
+            }
+        }
+
+        // Increase threshold to prevent rapid alternating/jittering on mostly vertical paths
+        if (Mathf.Abs(deltaX) > 0.05f)
+        {
+            // The original horizontal sprite faces RIGHT, so flip if moving LEFT (deltaX < 0)
+            bool flip = deltaX < 0f;
+            if (customer.bodyRenderer != null) customer.bodyRenderer.flipX = flip;
+            if (customer.headRenderer != null) customer.headRenderer.flipX = flip;
+        }
+    }
