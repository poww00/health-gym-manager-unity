+        bool shouldLogExitHidden = isExitHide && !customer.layeredExitHiddenLogged;
+        bool shouldLogVisible = isVisible && !customer.layeredEntranceVisibleLogged;
+        if (!shouldLogHidden && !shouldLogVisible && !shouldLogExitHidden)
+        {
+            return;
+        }
+
+        if (isVisible)
+        {
+            customer.layeredEntranceVisibleLogged = true;
+            customer.layeredEntranceVisibleTime = Time.time;
