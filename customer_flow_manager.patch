+        if (customer == null || !customer.usesLayeredCustomerSprites)
+        {
+            return;
+        }
+
+        Debug.Log(
+            "[CustomerFlowManager] Layered customer visibility false requested\n" +
+            $"Reason: {reason}\n" +
+            $"Renderer disable request: {isRendererDisableRequest}\n" +
+            $"Blocked early hide: {blocked}\n" +
+            $"Customer position: {FormatVector3(customer.worldPosition)}\n" +
+            $"Exit hide point: {FormatVector3(customer.exitSafeHidePoint)}\n" +
+            $"Distance to exit hide point: {GetDistanceLabel(distanceToExitHidePoint)}\n" +
+            $"Exit hide radius: {GetLayeredCustomerExitHideRadius():0.###}\n" +
+            $"Exit fade zone half width: {GetLayeredCustomerExitFadeZoneHalfWidth():0.###}\n" +
+            $"Exit fade zone half height: {GetLayeredCustomerExitFadeZoneHalfHeight():0.###}\n" +
+            $"Inside exit fade zone: {GetLayeredCustomerExitFadeDecision(customer).insideExitFadeZone}\n" +
+            $"Threshold condition: {GetLayeredCustomerExitFadeDecision(customer).passedLeftEntranceThreshold}\n" +
+            $"Hard cutoff: {GetLayeredCustomerExitFadeDecision(customer).passedHardCutoff}\n" +
+            $"Is exiting: {customer.layeredIsExiting || customer.state == CustomerState.Leaving}\n" +
+            $"Exit hide pending: {customer.layeredExitHidePending}\n" +
+            $"Exit fade-out started: {customer.layeredExitFadeOutStarted}\n" +
+            $"Exit fade-out completed: {customer.layeredExitFadeOutCompleted}\n" +
+            $"Body renderer enabled: {GetRendererEnabledLabel(customer.bodyRenderer)}\n" +
+            $"Head renderer enabled: {GetRendererEnabledLabel(customer.headRenderer)}");
+
+        if (blocked)
+        {
+            Debug.LogWarning(
+                "[CustomerFlowManager] Blocked early layered customer hide during exit.\n" +
+                $"Reason: {reason}\n" +
+                $"Customer position: {FormatVector3(customer.worldPosition)}\n" +
+                $"Exit hide point: {FormatVector3(customer.exitSafeHidePoint)}\n" +
+                $"Distance to exit hide point: {GetDistanceLabel(distanceToExitHidePoint)}\n" +
+                $"Exit hide radius: {GetLayeredCustomerExitHideRadius():0.###}\n" +
+                $"Exit fade zone half width: {GetLayeredCustomerExitFadeZoneHalfWidth():0.###}\n" +
+                $"Exit fade zone half height: {GetLayeredCustomerExitFadeZoneHalfHeight():0.###}");
+        }
+    }
+
+    private void SetLayeredCustomerRenderersEnabled(ActiveCustomer customer, bool isEnabled)
+    {
+        if (customer == null || !customer.usesLayeredCustomerSprites)
+        {
+            return;
+        }
+
+        if (customer.bodyRenderer != null)
+        {
+            customer.bodyRenderer.enabled = isEnabled;
+        }
+
+        if (customer.headRenderer != null)
+        {
+            customer.headRenderer.enabled = isEnabled;
+        }
+
+        if (customer.renderer != null &&
+            customer.renderer != customer.bodyRenderer &&
+            customer.renderer != customer.headRenderer)
+        {
+            customer.renderer.enabled = isEnabled;
+        }
+    }
+
+    private void SetLayeredCustomerRenderersAlpha(ActiveCustomer customer, float alpha)
+    {
+        if (customer == null || !customer.usesLayeredCustomerSprites)
+        {
+            return;
+        }
+
+        float safeAlpha = Mathf.Clamp01(alpha);
+        SetRendererAlpha(customer.bodyRenderer, safeAlpha);
+        SetRendererAlpha(customer.headRenderer, safeAlpha);
+
+        if (customer.renderer != null &&
+            customer.renderer != customer.bodyRenderer &&
+            customer.renderer != customer.headRenderer)
+        {
+            SetRendererAlpha(customer.renderer, safeAlpha);
+        }
+    }
+
+    private static void SetRendererAlpha(SpriteRenderer renderer, float alpha)
+    {
+        if (renderer == null)
+        {
+            return;
+        }
+
+        Color color = renderer.color;
+        color.a = Mathf.Clamp01(alpha);
+        renderer.color = color;
+    }
+
+    private static void SetRendererColorPreservingAlpha(SpriteRenderer renderer, Color color)
+    {
+        if (renderer == null)
+        {
+            return;
+        }
+
+        color.a = renderer.color.a;
+        renderer.color = color;
+    }
+
+    private LayeredEntrancePointInfo GetLayeredCustomerEntrancePointInfo()
+    {
+        float safeInset = Mathf.Clamp(layeredCustomerEntranceRevealInsetWorld, 0.35f, 0.45f);
+
+        bool hasDeskPoint = TryGetReceptionOrDeskPoint(out Vector3 deskPoint, out string deskSourceName);
+        Transform manualMarker = null;
+        bool manualMarkerCreated = false;
+        bool hasManualMarker = layeredCustomerUseManualEntranceMarker &&
+            TryGetOrCreateCustomerEntranceRevealMarker(out manualMarker, out manualMarkerCreated);
+        if (hasManualMarker && manualMarker != null)
+        {
+            Vector3 markerWorldPosition = manualMarker.position;
+            Vector3 manualRevealPoint = GetYOnlyManualEntranceRevealPoint(
+                markerWorldPosition,
+                manualMarker.name,
+                out bool revealPointXChanged,
+                out bool revealPointXForced,
+                out float markerBaseX,
+                out float requestedRevealPointX);
+            float manualRevealToDeskDistance = hasDeskPoint ? Vector3.Distance(manualRevealPoint, deskPoint) : -1f;
+            LayeredEntrancePointInfo markerInfo = new LayeredEntrancePointInfo
+            {
+                sourceName = manualMarker.name + (manualMarkerCreated ? " (auto-created)" : " transform"),
+                doorPassPoint = markerWorldPosition,
+                revealPoint = manualRevealPoint,
+                exitHidePoint = manualRevealPoint,
+                receptionOrDeskPoint = deskPoint,
+                hasReceptionOrDeskPoint = hasDeskPoint,
+                revealToDeskDistance = manualRevealToDeskDistance,
+                usedRendererFallback = false,
+                manualMarkerFound = true,
+                manualMarkerCreated = manualMarkerCreated,
+                usedManualMarker = true,
+                usedSerializedManualWorldPoint = false,
+                manualMarkerOverwritten = false,
+                manualMarkerWorldPosition = markerWorldPosition,
+                revealPointXChangedFromMarkerBase = revealPointXChanged,
+                revealPointXForcedToMarkerBase = revealPointXForced,
+                markerBaseX = markerBaseX,
+                requestedRevealPointX = requestedRevealPointX
+            };
+
+            WarnIfManualRevealPointNearDesk(markerInfo);
+            UpdateLayeredCustomerEntranceDebugPoints(markerInfo);
+            return markerInfo;
+        }
+
+        if (layeredCustomerUseManualEntranceWorldPoint)
+        {
+            Vector3 manualWorldPoint = GetYOnlyManualEntranceRevealPoint(
+                layeredCustomerManualEntranceRevealWorldPoint,
+                "layeredCustomerManualEntranceRevealWorldPoint",
+                out bool revealPointXChanged,
+                out bool revealPointXForced,
+                out float markerBaseX,
+                out float requestedRevealPointX);
+            float manualWorldToDeskDistance = hasDeskPoint ? Vector3.Distance(manualWorldPoint, deskPoint) : -1f;
+            LayeredEntrancePointInfo manualWorldInfo = new LayeredEntrancePointInfo
+            {
+                sourceName = "layeredCustomerManualEntranceRevealWorldPoint",
+                doorPassPoint = layeredCustomerManualEntranceRevealWorldPoint,
+                revealPoint = manualWorldPoint,
+                exitHidePoint = manualWorldPoint,
+                receptionOrDeskPoint = deskPoint,
+                hasReceptionOrDeskPoint = hasDeskPoint,
+                revealToDeskDistance = manualWorldToDeskDistance,
+                usedRendererFallback = false,
+                manualMarkerFound = false,
+                manualMarkerCreated = false,
+                usedManualMarker = false,
+                usedSerializedManualWorldPoint = true,
+                manualMarkerOverwritten = false,
+                manualMarkerWorldPosition = Vector3.zero,
+                revealPointXChangedFromMarkerBase = revealPointXChanged,
+                revealPointXForcedToMarkerBase = revealPointXForced,
+                markerBaseX = markerBaseX,
+                requestedRevealPointX = requestedRevealPointX
+            };
+
+            UpdateLayeredCustomerEntranceDebugPoints(manualWorldInfo);
+            return manualWorldInfo;
+        }
+
+        bool hasWaypointPoint = TryGetEntranceDoorPassPointFromWaypoints(out Vector3 waypointPoint, out string waypointSourceName);
+        bool hasRendererPoint = TryGetEntranceDoorPassPointFromRenderer(out Vector3 rendererPoint, out string rendererSourceName);
+
+        Vector3 doorPassPoint = hasWaypointPoint
+            ? waypointPoint
+            : hasRendererPoint
+                ? rendererPoint
+                : GetEntranceBaseWorldPosition();
+        string sourceName = hasWaypointPoint
+            ? waypointSourceName
+            : hasRendererPoint
+                ? rendererSourceName
+                : "GetEntranceBaseWorldPosition fallback";
+        bool usedRendererFallback = false;
+
+        if (hasRendererPoint)
+        {
+            float waypointToRendererDistance = Vector3.Distance(doorPassPoint, rendererPoint);
+            if (!hasWaypointPoint ||
+                waypointToRendererDistance > 0.55f ||
+                Mathf.Abs(doorPassPoint.y - rendererPoint.y) > 0.35f)
+            {
+                doorPassPoint = rendererPoint;
+                sourceName = rendererSourceName + " fallback";
+                usedRendererFallback = true;
+            }
+        }
+
+        Vector3 revealPoint = GetLayeredCustomerEntranceSafeRevealPoint(doorPassPoint, safeInset);
+        Vector3 exitHidePoint = revealPoint;
+        float revealToDeskDistance = hasDeskPoint ? Vector3.Distance(revealPoint, deskPoint) : -1f;
+
+        if (hasDeskPoint && hasRendererPoint)
+        {
+            Vector3 rendererRevealPoint = GetLayeredCustomerEntranceSafeRevealPoint(rendererPoint, safeInset);
+            float rendererRevealToDeskDistance = Vector3.Distance(rendererRevealPoint, deskPoint);
+            if (rendererRevealToDeskDistance > revealToDeskDistance + 0.15f)
+            {
+                doorPassPoint = rendererPoint;
+                sourceName = rendererSourceName + " fallback: entrance renderer farther from " + deskSourceName;
+                revealPoint = rendererRevealPoint;
+                exitHidePoint = revealPoint;
+                revealToDeskDistance = rendererRevealToDeskDistance;
+                usedRendererFallback = true;
+            }
+        }
+
+        if (hasDeskPoint && revealToDeskDistance <= 0.5f && hasRendererPoint)
+        {
+            doorPassPoint = rendererPoint;
+            sourceName = rendererSourceName + " fallback: reveal too close to " + deskSourceName;
+            revealPoint = GetLayeredCustomerEntranceSafeRevealPoint(doorPassPoint, safeInset);
+            exitHidePoint = revealPoint;
+            revealToDeskDistance = Vector3.Distance(revealPoint, deskPoint);
+            usedRendererFallback = true;
+        }
+
+        if (usedRendererFallback && !layeredCustomerEntranceFallbackWarningLogged)
+        {
+            layeredCustomerEntranceFallbackWarningLogged = true;
+            Debug.LogWarning(
+                "[CustomerFlowManager] Layered entrance reveal point used entrance renderer bounds fallback.\n" +
+                $"Source: {sourceName}\n" +
+                $"Door/pass point: {FormatVector3(doorPassPoint)}\n" +
+                $"Reveal point: {FormatVector3(revealPoint)}\n" +
+                $"Reception/desk point: {(hasDeskPoint ? FormatVector3(deskPoint) : "not found")}\n" +
+                $"Reveal-to-desk distance: {GetDistanceLabel(revealToDeskDistance)}");
+        }
+
+        LayeredEntrancePointInfo info = new LayeredEntrancePointInfo
+        {
+            sourceName = sourceName,
+            doorPassPoint = doorPassPoint,
+            revealPoint = revealPoint,
+            exitHidePoint = exitHidePoint,
+            receptionOrDeskPoint = deskPoint,
+            hasReceptionOrDeskPoint = hasDeskPoint,
+            revealToDeskDistance = revealToDeskDistance,
+            usedRendererFallback = usedRendererFallback,
+            manualMarkerFound = false,
+            manualMarkerCreated = false,
+            usedManualMarker = false,
+            usedSerializedManualWorldPoint = false,
+            manualMarkerOverwritten = false,
+            manualMarkerWorldPosition = Vector3.zero,
+            revealPointXChangedFromMarkerBase = false,
+            revealPointXForcedToMarkerBase = false,
+            markerBaseX = revealPoint.x,
+            requestedRevealPointX = revealPoint.x
+        };
+
+        UpdateLayeredCustomerEntranceDebugPoints(info);
+        return info;
+    }
+
+    private Vector3 GetYOnlyManualEntranceRevealPoint(
+        Vector3 markerBasePosition,
+        string sourceName,
+        out bool xChanged,
+        out bool xForcedToBase,
+        out float markerBaseX,
+        out float requestedRevealPointX)
+    {
+        markerBaseX = markerBasePosition.x;
+        Vector3 requestedPoint = markerBasePosition + layeredCustomerManualEntranceRevealOffset;
+        requestedRevealPointX = requestedPoint.x;
+        xChanged = Mathf.Abs(requestedPoint.x - markerBasePosition.x) > 0.0001f;
+        xForcedToBase = xChanged;
+
+        if (xChanged)
+        {
+            Debug.LogWarning(
+                "[CustomerFlowManager] Manual entrance reveal offset attempted to change X; X is locked to the marker base position.\n" +
+                $"Source: {sourceName}\n" +
+                $"Marker base position: {FormatVector3(markerBasePosition)}\n" +
+                $"Requested final reveal point: {FormatVector3(requestedPoint)}\n" +
+                $"Forced final reveal point X: {markerBasePosition.x:0.###}");
+        }
+
+        return new Vector3(
+            markerBasePosition.x,
+            markerBasePosition.y + layeredCustomerManualEntranceRevealOffset.y,
+            markerBasePosition.z);
+    }
+
+    private Vector3 GetLayeredCustomerEntranceSafeRevealPoint(Vector3 doorPassPoint, float safeInset)
+    {
+        return doorPassPoint + new Vector3(safeInset, 0f, 0f);
+    }
+
+    private bool TryGetOrCreateCustomerEntranceRevealMarker(out Transform markerTransform, out bool created)
+    {
+        created = false;
+        markerTransform = null;
+
+        string markerName = string.IsNullOrWhiteSpace(layeredCustomerEntranceMarkerName)
+            ? "CustomerEntranceRevealMarker"
+            : layeredCustomerEntranceMarkerName.Trim();
+        GameObject markerObject = GameObject.Find(markerName);
+        if (markerObject != null)
+        {
+            markerTransform = markerObject.transform;
+            return true;
+        }
+
+        markerObject = new GameObject(markerName);
+        markerObject.hideFlags = HideFlags.None;
+        markerTransform = markerObject.transform;
+        Transform parent = transform != null ? transform : EnsureRuntimeRoot();
+        markerTransform.SetParent(parent, false);
+        markerTransform.position = GetDefaultManualEntranceMarkerWorldPosition();
+        created = true;
+        return true;
+    }
+
+    private Vector3 GetDefaultManualEntranceMarkerWorldPosition()
+    {
+        float safeInset = Mathf.Clamp(layeredCustomerEntranceRevealInsetWorld, 0.35f, 0.45f);
+
+        GameObject debugDoor = GameObject.Find("DEBUG_EntranceDoorOrPassPoint");
+        if (debugDoor != null)
+        {
+            return debugDoor.transform.position + new Vector3(safeInset, 0f, 0f);
+        }
+
+        bool hasRendererPoint = TryGetEntranceDoorPassPointFromRenderer(out Vector3 rendererPoint, out _);
+        bool hasDeskPoint = TryGetReceptionOrDeskPoint(out Vector3 deskPoint, out _);
+        SpriteRenderer deskRenderer = FindReceptionOrDeskRenderer();
+        if (hasRendererPoint)
+        {
+            return rendererPoint + new Vector3(safeInset, 0f, 0f);
+        }
+
+        if (deskRenderer != null)
+        {
+            Bounds deskBounds = deskRenderer.bounds;
+            return new Vector3(
+                deskBounds.min.x - 0.12f,
+                deskBounds.center.y,
+                0f);
+        }
+
+        if (hasDeskPoint)
+        {
+            return new Vector3(deskPoint.x - 0.55f, deskPoint.y, 0f);
+        }
+
+        if (TryGetEntranceDoorPassPointFromWaypoints(out Vector3 waypointPoint, out _))
+        {
+            return waypointPoint + new Vector3(safeInset, 0f, 0f);
+        }
+
+        return GetEntranceBaseWorldPosition() + new Vector3(safeInset, 0f, 0f);
+    }
+
+    private void WarnIfManualRevealPointNearDesk(LayeredEntrancePointInfo info)
+    {
+        if (!info.hasReceptionOrDeskPoint || info.revealToDeskDistance > 0.5f)
+        {
+            return;
+        }
+
+        Debug.LogWarning(
+            "[CustomerFlowManager] Manual entrance reveal marker is close to the reception/desk point. Marker remains authoritative and was not overwritten.\n" +
+            $"Marker found: {info.manualMarkerFound}\n" +
+            $"Marker world position: {FormatVector3(info.manualMarkerWorldPosition)}\n" +
+            $"Final entrance reveal point: {FormatVector3(info.revealPoint)}\n" +
+            $"Reception/desk point: {FormatVector3(info.receptionOrDeskPoint)}\n" +
+            $"Reveal-to-desk distance: {GetDistanceLabel(info.revealToDeskDistance)}");
+    }
+
+    private bool TryGetEntranceDoorPassPointFromWaypoints(out Vector3 point, out string sourceName)
+    {
+        if (gridManager != null && gridManager.TryGetEntranceWalkWorldPosition(0f, out Vector3 passPoint))
+        {
+            point = passPoint;
+            sourceName = "GridManager.TryGetEntranceWalkWorldPosition";
+            return true;
+        }
+
+        point = GetEntrancePassWorldPosition();
+        sourceName = "CustomerFlowManager.GetEntrancePassWorldPosition fallback";
+        return true;
+    }
+
+    private bool TryGetEntranceDoorPassPointFromRenderer(out Vector3 point, out string sourceName)
+    {
+        SpriteRenderer renderer = FindEntranceRendererForRevealPoint();
+        if (renderer != null)
+        {
+            Bounds bounds = renderer.bounds;
+            point = new Vector3(bounds.max.x, bounds.center.y, 0f);
+            sourceName = renderer.name + ".bounds.maxX/centerY";
+            return true;
+        }
+
+        point = Vector3.zero;
+        sourceName = "not found";
+        return false;
+    }
+
+    private bool TryGetReceptionOrDeskPoint(out Vector3 point, out string sourceName)
+    {
+        SpriteRenderer renderer = FindReceptionOrDeskRenderer();
+        if (renderer != null)
+        {
+            point = renderer.bounds.center;
+            point.z = 0f;
+            sourceName = renderer.name + ".bounds.center";
+            return true;
+        }
+
+        point = Vector3.zero;
+        sourceName = "not found";
+        return false;
+    }
+
+    private void UpdateLayeredCustomerEntranceDebugPoints(LayeredEntrancePointInfo info)
+    {
+        if (!showLayeredCustomerEntranceDebugMarkers)
+        {
+            return;
+        }
+
+        hasLayeredEntranceDebugPoints = true;
+        debugEntranceDoorOrPassPoint = info.doorPassPoint;
+        debugEntranceRevealPoint = info.revealPoint;
+        debugExitHidePoint = info.exitHidePoint;
+        debugReceptionOrDeskPoint = info.receptionOrDeskPoint;
+        hasDebugReceptionOrDeskPoint = info.hasReceptionOrDeskPoint;
+
+        UpsertLayeredCustomerDebugMarker("DEBUG_EntranceDoorOrPassPoint", info.doorPassPoint);
+        UpsertLayeredCustomerDebugMarker("DEBUG_EntranceRevealPoint", info.revealPoint);
+        UpsertLayeredCustomerDebugMarker("DEBUG_ExitHidePoint", info.exitHidePoint);
+        UpsertLayeredCustomerDebugMarker("DEBUG_ExitFadeZone", info.exitHidePoint);
+        if (info.hasReceptionOrDeskPoint)
+        {
+            UpsertLayeredCustomerDebugMarker("DEBUG_ReceptionOrDeskPoint", info.receptionOrDeskPoint);
+        }
+    }
+
+    private void UpsertLayeredCustomerDebugMarker(string objectName, Vector3 position)
+    {
+        GameObject marker = GameObject.Find(objectName);
+        if (marker == null)
+        {
+            marker = new GameObject(objectName);
+        }
+
+        marker.transform.SetParent(EnsureRuntimeRoot(), false);
+        marker.transform.position = position;
+    }
