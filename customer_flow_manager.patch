+    private void SaveLayeredCustomerEntranceRevealPointForEntry(ActiveCustomer customer, string reason)
+    {
+        if (customer == null || !customer.usesLayeredCustomerSprites)
+        {
+            return;
+        }
+
+        customer.entranceRevealPointUsedForEntry = customer.entranceSafeRevealPoint;
+        customer.hasLayeredEntranceRevealPointForEntry = true;
+        customer.exitSafeHidePoint = customer.entranceRevealPointUsedForEntry;
+        customer.exitHidePointOverwrittenToEntranceReveal = false;
+
+        Debug.Log(
+            "[CustomerFlowManager] Layered customer entrance reveal point saved for exit reuse\n" +
+            $"Reason: {reason}\n" +
+            $"Entrance reveal point used for entry: {FormatVector3(customer.entranceSafeRevealPoint)}\n" +
+            $"Saved state.EntranceRevealPoint: {FormatVector3(customer.entranceRevealPointUsedForEntry)}\n" +
+            $"Exit hide point initialized from entry reveal point: {FormatVector3(customer.exitSafeHidePoint)}");
+    }
+
+    private void EnsureLayeredCustomerHasEntranceRevealPoint(ActiveCustomer customer, string reason)
+    {
+        if (customer == null || !customer.usesLayeredCustomerSprites || customer.hasLayeredEntranceRevealPointForEntry)
+        {
+            return;
+        }
+
+        LayeredEntrancePointInfo entranceInfo = GetLayeredCustomerEntrancePointInfo();
+        ApplyLayeredEntrancePointInfo(customer, entranceInfo);
+        SaveLayeredCustomerEntranceRevealPointForEntry(customer, reason);
+        Debug.LogWarning(
+            "[CustomerFlowManager] Layered customer exit had no saved entrance reveal point; using the current entrance reveal point fallback.\n" +
+            $"Reason: {reason}\n" +
+            $"Entrance point source: {entranceInfo.sourceName}\n" +
+            $"Fallback entrance reveal point: {FormatVector3(customer.entranceRevealPointUsedForEntry)}");
+    }
+
+    private Vector3 GetLayeredCustomerEntranceRevealPoint(ActiveCustomer customer)
+    {
+        if (customer != null && customer.hasLayeredEntranceRevealPointForEntry)
+        {
+            return customer.entranceRevealPointUsedForEntry;
+        }
+
+        return GetLayeredCustomerEntrancePointInfo().revealPoint;
+    }
+
+    private void ForceLayeredCustomerExitHidePointToEntranceReveal(ActiveCustomer customer, string reason)
+    {
+        if (customer == null || !customer.usesLayeredCustomerSprites)
+        {
+            return;
+        }
+
+        Vector3 entranceRevealPoint = GetLayeredCustomerEntranceRevealPoint(customer);
+        Vector3 previousExitHidePoint = customer.exitSafeHidePoint;
+        bool overwritten = GetPlanarDistance(previousExitHidePoint, entranceRevealPoint) > 0.01f;
+        if (overwritten)
+        {
+            Debug.LogWarning(
+                "[CustomerFlowManager] Layered customer exit hide point differed from the saved entrance reveal point; forcing exit to reuse entry point.\n" +
+                $"Reason: {reason}\n" +
+                $"Previous exit hide point: {FormatVector3(previousExitHidePoint)}\n" +
+                $"Saved entrance reveal point: {FormatVector3(entranceRevealPoint)}");
+        }
+
+        customer.entranceSafeRevealPoint = entranceRevealPoint;
+        customer.entranceRevealPointUsedForEntry = entranceRevealPoint;
+        customer.hasLayeredEntranceRevealPointForEntry = true;
+        customer.exitSafeHidePoint = entranceRevealPoint;
+        customer.exitHidePointOverwrittenToEntranceReveal = overwritten;
+
+        ValidateLayeredCustomerExitUsesEntranceRevealPoint(customer, reason);
+    }
+
+    private void ValidateLayeredCustomerExitUsesEntranceRevealPoint(ActiveCustomer customer, string reason)
+    {
+        if (customer == null || !customer.usesLayeredCustomerSprites)
+        {
+            return;
+        }
+
+        float exitToEntryDistance = GetPlanarDistance(customer.exitSafeHidePoint, customer.entranceRevealPointUsedForEntry);
+        if (exitToEntryDistance > 0.01f)
+        {
+            Debug.LogError(
+                "[CustomerFlowManager] Layered customer exit hide point is not equal to the entrance reveal point.\n" +
+                $"Reason: {reason}\n" +
+                $"Entrance reveal point: {FormatVector3(customer.entranceRevealPointUsedForEntry)}\n" +
+                $"Exit hide point: {FormatVector3(customer.exitSafeHidePoint)}\n" +
+                $"Distance: {exitToEntryDistance:0.###}");
+        }
+    }
+
+    private void UpdateLayeredCustomerExitHide(ActiveCustomer customer)
+    {
+        if (customer == null ||
+            !customer.usesLayeredCustomerSprites ||
+            !customer.waitsForLayeredExitHide ||
+            customer.layeredExitHidden)
+        {
+            return;
+        }
+
+        ForceLayeredCustomerExitHidePointToEntranceReveal(customer, "exit hide update");
+        LayeredExitFadeDecision decision = GetLayeredCustomerExitFadeDecision(customer);
+        if (decision.passedHardCutoff)
+        {
+            HardCutoffLayeredCustomerExitHide(customer, decision);
+            return;
+        }
+
+        if (!decision.shouldStartFadeOut)
+        {
+            SetLayeredCustomerVisible(customer, true, "exiting before exit hide point");
+            return;
+        }
+
+        TryStartLayeredCustomerExitFadeOut(customer, decision.reason, decision);
+    }
+
+    private float GetLayeredCustomerEntranceRevealRadius()
+    {
+        return Mathf.Max(0.05f, layeredCustomerEntranceRevealRadius);
+    }
