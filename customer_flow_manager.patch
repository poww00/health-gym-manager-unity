+    private void PrepareLayeredCustomerEntranceReveal(ActiveCustomer customer, bool enterThroughEntrance)
+    {
+        if (customer == null || !customer.usesLayeredCustomerSprites)
+        {
+            return;
+        }
+
+        if (!enterThroughEntrance)
+        {
+            customer.waitsForLayeredEntranceReveal = false;
+            customer.layeredExitHidden = false;
+            customer.layeredExitFadeOutActive = false;
+            customer.layeredIsExiting = false;
+            customer.layeredExitHidePending = false;
+            customer.layeredExitFadeOutStarted = false;
+            customer.layeredExitFadeOutCompleted = false;
+            ApplyLayeredCustomerVisualScale(customer);
+            SetLayeredCustomerVisible(customer, true, "entrance bypassed, layered customer visible");
+            SetLayeredCustomerRenderersAlpha(customer, 1f);
+            return;
+        }
+
+        LayeredEntrancePointInfo entranceInfo = GetLayeredCustomerEntrancePointInfo();
+        ApplyLayeredEntrancePointInfo(customer, entranceInfo);
+        SaveLayeredCustomerEntranceRevealPointForEntry(customer, "entrance prepared");
+        customer.waitsForLayeredEntranceReveal = true;
+        customer.waitsForLayeredExitHide = false;
+        customer.layeredExitHidden = false;
+        customer.layeredEntranceFadeInActive = false;
+        customer.layeredExitFadeOutActive = false;
+        customer.layeredIsExiting = false;
+        customer.layeredExitHidePending = false;
+        customer.layeredExitFadeOutStarted = false;
+        customer.layeredExitFadeOutCompleted = false;
+        customer.layeredExitFadeOutElapsed = 0f;
+        ApplyLayeredCustomerVisualScale(customer);
+        SetLayeredCustomerVisible(customer, false, "entrance hidden before reveal point");
+        SetLayeredCustomerRenderersAlpha(customer, 1f);
+        LogLayeredCustomerEntranceRevealStatus(customer, false);
+    }
+
+    private void UpdateLayeredCustomerEntranceReveal(ActiveCustomer customer)
+    {
+        if (customer == null || !customer.usesLayeredCustomerSprites || !customer.waitsForLayeredEntranceReveal)
+        {
+            return;
+        }
+
+        Vector3 safeRevealPoint = customer.entranceSafeRevealPoint;
+        float revealRadius = GetLayeredCustomerEntranceRevealRadius();
+        float revealDistance = Vector3.Distance(customer.worldPosition, safeRevealPoint);
+        bool reachedRevealPoint = revealDistance <= revealRadius;
+
+        if (!reachedRevealPoint)
+        {
+            SetLayeredCustomerVisible(customer, false, "waiting for entrance reveal point");
+            return;
+        }
+
+        customer.waitsForLayeredEntranceReveal = false;
+        customer.hasPassedEntrance = true;
+        customer.entranceVisibleTransitionPosition = customer.worldPosition;
+        customer.entryRevealDistanceAtVisible = revealDistance;
+        WarnIfLayeredCustomerRevealTransitionLooksWrong(customer, revealDistance);
+        StartLayeredCustomerEntranceFadeIn(customer);
+        LogLayeredCustomerEntranceRevealStatus(customer, true);
+    }
