+    private float GetLayeredCustomerExitFadeDistanceWorld()
+    {
+        return Mathf.Max(GetLayeredCustomerExitHideRadius(), layeredCustomerExitFadeDistanceWorld);
+    }
+
+    private float GetLayeredCustomerExitFadeZoneHalfWidth()
+    {
+        return Mathf.Max(0.05f, layeredCustomerExitFadeZoneHalfWidth);
