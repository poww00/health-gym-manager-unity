+    private void ApplyLayeredEntrancePointInfo(ActiveCustomer customer, LayeredEntrancePointInfo entranceInfo)
+    {
+        if (customer == null)
+        {
+            return;
+        }
+
+        customer.entranceDoorPassPointSourceName = entranceInfo.sourceName;
+        customer.entranceOriginalWaypoint = entranceInfo.doorPassPoint;
+        customer.entranceDoorPassPoint = entranceInfo.doorPassPoint;
+        customer.entranceSafeRevealPoint = entranceInfo.revealPoint;
+        customer.exitSafeHidePoint = entranceInfo.revealPoint;
+        customer.receptionOrDeskPoint = entranceInfo.receptionOrDeskPoint;
+        customer.hasReceptionOrDeskPoint = entranceInfo.hasReceptionOrDeskPoint;
+        customer.revealToDeskDistance = entranceInfo.revealToDeskDistance;
+        customer.manualEntranceMarkerFound = entranceInfo.manualMarkerFound;
+        customer.manualEntranceMarkerCreated = entranceInfo.manualMarkerCreated;
+        customer.manualEntranceMarkerOverwritten = entranceInfo.manualMarkerOverwritten;
+        customer.usedManualEntranceMarker = entranceInfo.usedManualMarker;
+        customer.usedSerializedManualEntranceWorldPoint = entranceInfo.usedSerializedManualWorldPoint;
+        customer.manualEntranceMarkerWorldPosition = entranceInfo.manualMarkerWorldPosition;
+        customer.revealPointXChangedFromMarkerBase = entranceInfo.revealPointXChangedFromMarkerBase;
+        customer.revealPointXForcedToMarkerBase = entranceInfo.revealPointXForcedToMarkerBase;
+        customer.entranceMarkerBaseX = entranceInfo.markerBaseX;
+        customer.requestedEntranceRevealPointX = entranceInfo.requestedRevealPointX;
+
+        bool usesManualRevealBasis = customer.usedManualEntranceMarker || customer.usedSerializedManualEntranceWorldPoint;
+        if (usesManualRevealBasis &&
+            Mathf.Abs(customer.entranceSafeRevealPoint.x - customer.entranceMarkerBaseX) > 0.0001f)
+        {
+            float finalRevealX = customer.entranceSafeRevealPoint.x;
+            Debug.LogWarning(
+                "[CustomerFlowManager] Final manual entrance reveal point X differed from the marker base X; forcing X back to the marker base.\n" +
+                $"Marker base X: {customer.entranceMarkerBaseX:0.###}\n" +
+                $"Final reveal X before lock: {finalRevealX:0.###}");
+            customer.entranceSafeRevealPoint.x = customer.entranceMarkerBaseX;
+            customer.exitSafeHidePoint.x = customer.entranceMarkerBaseX;
+            customer.revealPointXChangedFromMarkerBase = true;
+            customer.revealPointXForcedToMarkerBase = true;
+            customer.requestedEntranceRevealPointX = finalRevealX;
+        }
+
+        customer.exitSafeHidePoint = customer.entranceSafeRevealPoint;
+    }
