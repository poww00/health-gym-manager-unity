+
+    private float GetLayeredCustomerExitFadeZoneHalfHeight()
+    {
+        return Mathf.Max(0.05f, layeredCustomerExitFadeZoneHalfHeight);
+    }
+
+    private float GetLayeredCustomerExitFadeStartInsetWorld()
+    {
+        return Mathf.Max(0.05f, layeredCustomerExitFadeStartInsetWorld);
+    }
+
+    private float GetLayeredCustomerExitHardCutoffOffsetWorld()
+    {
+        return Mathf.Max(0.01f, layeredCustomerExitHardCutoffOffsetWorld);
+    }
+
+    private float GetLayeredCustomerExitFadeOutSeconds()
+    {
+        return Mathf.Clamp(layeredCustomerExitFadeOutSeconds, 0.15f, 0.25f);
