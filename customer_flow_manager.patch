+            return;
+        }
+
+        EnsureLayeredCustomerHasEntranceRevealPoint(customer, "exit prepare fallback");
+        ForceLayeredCustomerExitHidePointToEntranceReveal(customer, "exit prepare");
+        customer.waitsForLayeredEntranceReveal = false;
+        customer.waitsForLayeredExitHide = true;
+        customer.layeredExitHidden = false;
+        customer.layeredEntranceFadeInActive = false;
+        customer.layeredExitFadeOutActive = false;
