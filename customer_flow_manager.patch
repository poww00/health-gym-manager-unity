+
+    private bool TryStartLayeredCustomerExitFadeOut(
+        ActiveCustomer customer,
+        string reason,
+        LayeredExitFadeDecision decision)
+    {
+        if (customer == null || !customer.usesLayeredCustomerSprites)
+        {
+            return false;
+        }
+
+        if (decision.passedHardCutoff)
+        {
+            HardCutoffLayeredCustomerExitHide(customer, decision);
+            return true;
+        }
+
+        if (!decision.shouldStartFadeOut)
+        {
+            LogLayeredCustomerHideRequest(customer, false, reason + " / blocked fade-out start", decision.distanceToExitHidePoint, true);
+            return false;
+        }
+
+        if (ShouldBlockLayeredExitFadeNearDesk(customer, decision, reason))
+        {
+            return false;
+        }
+
+        if ((customer.bodyRenderer != null && !customer.bodyRenderer.enabled) ||
+            (customer.headRenderer != null && !customer.headRenderer.enabled))
+        {
+            Debug.LogWarning(
+                "[CustomerFlowManager] Layered customer exit fade-out was requested after a renderer was already disabled.\n" +
+                $"Body renderer enabled: {GetRendererEnabledLabel(customer.bodyRenderer)}\n" +
+                $"Head renderer enabled: {GetRendererEnabledLabel(customer.headRenderer)}");
+        }
+
+        ApplyLayeredCustomerVisualScale(customer);
+        customer.waitsForLayeredExitHide = false;
+        customer.layeredExitHidePending = false;
+        customer.layeredExitHidden = false;
+        customer.exitFadeOutStartedPosition = customer.worldPosition;
+        customer.exitFadeOutStartToHideDistance = decision.distanceToExitHidePoint;
+        customer.layeredEntranceFadeInActive = false;
+        customer.layeredExitFadeOutActive = true;
+        customer.layeredExitFadeOutStarted = true;
+        customer.layeredExitFadeOutCompleted = false;
+        customer.layeredExitFadeOutElapsed = 0f;
+        customer.layeredExitFadeOutStartedLogged = true;
+        SetLayeredCustomerVisible(customer, true, reason + " / fade-out started");
+        SetLayeredCustomerRenderersAlpha(customer, 1f);
+        WarnIfLayeredCustomerBodyHeadAlphaMismatch(customer, "exit fade-out started");
+
+        Debug.Log(
+            "[CustomerFlowManager] Layered customer exit fade-out started\n" +
+            $"Reason: {reason}\n" +
+            $"Fade-out started reason: {decision.reason}\n" +
+            $"Layered customer fade seconds: {GetLayeredCustomerFadeSeconds():0.###}\n" +
+            $"Entry fade-in seconds: {GetLayeredCustomerEntranceFadeInSeconds():0.###}\n" +
+            $"Fade-out seconds: {GetLayeredCustomerExitFadeOutSeconds():0.###}\n" +
+            $"Exit fade-out start alpha: 1\n" +
+            $"Exit fade-out end alpha: 0\n" +
+            $"Body/Head alpha same: {AreLayeredCustomerBodyHeadAlphasEqual(customer)}\n" +
+            $"Entrance reveal point used for entry: {FormatVector3(customer.entranceSafeRevealPoint)}\n" +
+            $"Saved state.EntranceRevealPoint: {FormatVector3(customer.entranceRevealPointUsedForEntry)}\n" +
+            $"Exit hide point used for leaving: {FormatVector3(customer.exitSafeHidePoint)}\n" +
+            $"Exit hide point equals entrance reveal point: {GetPlanarDistance(customer.exitSafeHidePoint, GetLayeredCustomerEntranceRevealPoint(customer)) <= 0.01f}\n" +
+            $"ExitFadeZone center: {FormatVector3(customer.exitSafeHidePoint)}\n" +
+            $"Fade-out started position: {FormatVector3(customer.exitFadeOutStartedPosition)}\n" +
+            $"Fade-out start to hide point distance: {GetDistanceLabel(customer.exitFadeOutStartToHideDistance)}\n" +
+            $"Fade-out started distance to EntranceRevealPoint: {GetDistanceLabel(GetPlanarDistance(customer.exitFadeOutStartedPosition, GetLayeredCustomerEntranceRevealPoint(customer)))}\n" +
+            $"Fade-out started distance to desk/reception point: {GetDistanceLabel(customer.hasReceptionOrDeskPoint ? GetPlanarDistance(customer.exitFadeOutStartedPosition, customer.receptionOrDeskPoint) : -1f)}\n" +
+            $"Inside exit fade zone: {decision.insideExitFadeZone}\n" +
+            $"Distance condition: {decision.withinFadeDistance}\n" +
+            $"Left threshold condition: {decision.passedLeftEntranceThreshold}\n" +
+            $"Hard cutoff: {decision.passedHardCutoff}\n" +
+            $"Exit fade zone half size: ({GetLayeredCustomerExitFadeZoneHalfWidth():0.###}, {GetLayeredCustomerExitFadeZoneHalfHeight():0.###})\n" +
+            $"Body renderer enabled: {GetRendererEnabledLabel(customer.bodyRenderer)}\n" +
+            $"Head renderer enabled: {GetRendererEnabledLabel(customer.headRenderer)}\n" +
+            $"Current visual root scale: {FormatVector3(customer.visual != null ? customer.visual.transform.localScale : Vector3.zero)}");
+        return true;
+    }
+
+    private bool ShouldBlockLayeredExitFadeNearDesk(ActiveCustomer customer, LayeredExitFadeDecision decision, string reason)
+    {
+        if (customer == null ||
+            !customer.usesLayeredCustomerSprites ||
+            !customer.hasReceptionOrDeskPoint ||
+            decision.passedHardCutoff)
+        {
+            return false;
+        }
+
+        float distanceToEntranceRevealPoint = GetPlanarDistance(customer.worldPosition, GetLayeredCustomerEntranceRevealPoint(customer));
+        float distanceToDeskPoint = GetPlanarDistance(customer.worldPosition, customer.receptionOrDeskPoint);
+        if (distanceToDeskPoint >= distanceToEntranceRevealPoint)
+        {
+            return false;
+        }
+
+        Debug.LogWarning(
+            "[CustomerFlowManager] Blocked layered customer exit fade-out because the customer is closer to the desk/reception point than the saved entrance reveal point.\n" +
+            $"Reason: {reason}\n" +
+            $"Customer position: {FormatVector3(customer.worldPosition)}\n" +
+            $"Saved state.EntranceRevealPoint: {FormatVector3(GetLayeredCustomerEntranceRevealPoint(customer))}\n" +
+            $"Exit hide point used for leaving: {FormatVector3(customer.exitSafeHidePoint)}\n" +
+            $"Reception/desk point: {FormatVector3(customer.receptionOrDeskPoint)}\n" +
+            $"Distance to entrance reveal point: {GetDistanceLabel(distanceToEntranceRevealPoint)}\n" +
+            $"Distance to desk/reception point: {GetDistanceLabel(distanceToDeskPoint)}\n" +
+            $"ExitFadeZone center: {FormatVector3(customer.exitSafeHidePoint)}");
+        return true;
+    }
+
+    private void HardCutoffLayeredCustomerExitHide(ActiveCustomer customer, LayeredExitFadeDecision decision)
+    {
+        if (customer == null || !customer.usesLayeredCustomerSprites)
+        {
+            return;
+        }
+
+        customer.waitsForLayeredExitHide = false;
+        customer.layeredExitHidePending = false;
+        customer.layeredExitFadeOutActive = false;
+        customer.layeredExitFadeOutStarted = false;
+        customer.layeredExitFadeOutCompleted = true;
+        customer.layeredExitHidden = true;
+        customer.exitFadeOutStartedPosition = customer.worldPosition;
+        customer.exitFadeOutStartToHideDistance = decision.distanceToExitHidePoint;
+        customer.exitHiddenTransitionPosition = customer.worldPosition;
+        customer.exitHideDistanceAtHidden = decision.distanceToExitHidePoint;
+        customer.exitHiddenToDeskDistance = customer.hasReceptionOrDeskPoint
+            ? GetPlanarDistance(customer.exitHiddenTransitionPosition, customer.receptionOrDeskPoint)
+            : -1f;
+
+        Debug.LogWarning(
+            "[LayeredCustomer] Hard cutoff hide because customer passed exit boundary\n" +
+            $"Fade-out started reason: hard-cutoff\n" +
+            $"Customer position: {FormatVector3(customer.worldPosition)}\n" +
+            $"Saved state.EntranceRevealPoint: {FormatVector3(GetLayeredCustomerEntranceRevealPoint(customer))}\n" +
+            $"Exit hide point: {FormatVector3(customer.exitSafeHidePoint)}\n" +
+            $"Exit hide point equals entrance reveal point: {GetPlanarDistance(customer.exitSafeHidePoint, GetLayeredCustomerEntranceRevealPoint(customer)) <= 0.01f}\n" +
+            $"ExitFadeZone center: {FormatVector3(customer.exitSafeHidePoint)}\n" +
+            $"Distance to exit hide point: {GetDistanceLabel(decision.distanceToExitHidePoint)}\n" +
+            $"Inside exit fade zone: {decision.insideExitFadeZone}\n" +
+            $"Distance condition: {decision.withinFadeDistance}\n" +
+            $"Left threshold condition: {decision.passedLeftEntranceThreshold}\n" +
+            $"Hard cutoff: {decision.passedHardCutoff}\n" +
+            $"Renderer disabled position: {FormatVector3(customer.exitHiddenTransitionPosition)}\n" +
+            $"Renderer disabled distance to exit hide point: {GetDistanceLabel(customer.exitHideDistanceAtHidden)}");
+
+        SetLayeredCustomerRenderersAlpha(customer, 0f);
+        SetLayeredCustomerVisible(customer, false, "hard-cutoff");
+        SetLayeredCustomerRenderersAlpha(customer, 1f);
+        LogLayeredCustomerEntranceRevealStatus(customer, false);
+    }
+
+    private void UpdateLayeredCustomerExitFade(ActiveCustomer customer, float deltaTime)
+    {
+        if (customer == null || !customer.usesLayeredCustomerSprites || !customer.layeredExitFadeOutActive)
+        {
+            return;
+        }
+
+        WarnIfLayeredExitFadeRenderersMismatch(customer);
+        ApplyLayeredCustomerVisualScale(customer);
+
+        float fadeSeconds = GetLayeredCustomerFadeSeconds();
+        customer.layeredExitFadeOutElapsed += Mathf.Max(0f, deltaTime);
+        float alpha = 1f - EvaluateLayeredCustomerFade01(customer.layeredExitFadeOutElapsed, fadeSeconds);
+        SetLayeredCustomerRenderersAlpha(customer, alpha);
+        WarnIfLayeredCustomerBodyHeadAlphaMismatch(customer, "exit fade-out update");
+
+        if (alpha <= 0f)
+        {
+            CompleteLayeredCustomerExitFadeOut(customer);
+        }
+    }
+
+    private void CompleteLayeredCustomerExitFadeOut(ActiveCustomer customer)
+    {
+        if (customer == null || !customer.usesLayeredCustomerSprites)
+        {
+            return;
+        }
+
+        customer.layeredExitFadeOutActive = false;
+        customer.exitHiddenTransitionPosition = customer.worldPosition;
+        customer.exitHideDistanceAtHidden = GetPlanarDistance(customer.exitHiddenTransitionPosition, customer.exitSafeHidePoint);
+        customer.exitHiddenToDeskDistance = customer.hasReceptionOrDeskPoint
+            ? GetPlanarDistance(customer.exitHiddenTransitionPosition, customer.receptionOrDeskPoint)
+            : -1f;
+        customer.layeredExitHidden = true;
+        customer.layeredExitFadeOutStarted = true;
+        customer.layeredExitFadeOutCompleted = true;
+        customer.layeredExitHidePending = false;
+        customer.layeredExitFadeOutCompletedLogged = true;
+        SetLayeredCustomerRenderersAlpha(customer, 0f);
+        WarnIfLayeredCustomerBodyHeadAlphaMismatch(customer, "exit fade-out completed before disable");
+        SetLayeredCustomerVisible(customer, false, "exit fade-out completed");
+        SetLayeredCustomerRenderersAlpha(customer, 1f);
+        WarnIfLayeredCustomerBodyHeadAlphaMismatch(customer, "exit fade-out reset for next entry");
+        WarnIfLayeredCustomerExitTransitionLooksWrong(customer, customer.exitHideDistanceAtHidden);
+        LogLayeredCustomerEntranceRevealStatus(customer, false);
+
+        Debug.Log(
+            "[CustomerFlowManager] Layered customer exit fade-out completed\n" +
+            $"Layered customer fade seconds: {GetLayeredCustomerFadeSeconds():0.###}\n" +
+            $"Entry fade-in duration: {GetLayeredCustomerEntranceFadeInSeconds():0.###}\n" +
+            $"Fade-out seconds: {GetLayeredCustomerExitFadeOutSeconds():0.###}\n" +
+            $"Exit fade-out start alpha: 1\n" +
+            $"Exit fade-out end alpha: 0\n" +
+            $"Renderer alpha reset for next entry: 1\n" +
+            $"Body alpha: {GetRendererAlphaLabel(customer.bodyRenderer)}\n" +
+            $"Head alpha: {GetRendererAlphaLabel(customer.headRenderer)}\n" +
+            $"Body/Head alpha same: {AreLayeredCustomerBodyHeadAlphasEqual(customer)}\n" +
+            $"Saved state.EntranceRevealPoint: {FormatVector3(GetLayeredCustomerEntranceRevealPoint(customer))}\n" +
+            $"Exit hide point used for leaving: {FormatVector3(customer.exitSafeHidePoint)}\n" +
+            $"Exit hide point equals entrance reveal point: {GetPlanarDistance(customer.exitSafeHidePoint, GetLayeredCustomerEntranceRevealPoint(customer)) <= 0.01f}\n" +
+            $"ExitFadeZone center: {FormatVector3(customer.exitSafeHidePoint)}\n" +
+            $"Renderer disabled position: {FormatVector3(customer.exitHiddenTransitionPosition)}\n" +
+            $"Renderer disabled distance to exit hide point: {GetDistanceLabel(customer.exitHideDistanceAtHidden)}\n" +
+            $"Renderer disabled distance to desk point: {GetDistanceLabel(customer.exitHiddenToDeskDistance)}\n" +
+            $"Body renderer enabled after fade-out: {GetRendererEnabledLabel(customer.bodyRenderer)}\n" +
+            $"Head renderer enabled after fade-out: {GetRendererEnabledLabel(customer.headRenderer)}\n" +
+            $"Current visual root scale: {FormatVector3(customer.visual != null ? customer.visual.transform.localScale : Vector3.zero)}\n" +
+            $"HeadLocalOffset: {FormatVector3(layeredCustomerHeadLocalOffset)}");
+    }
+
+    private void WarnIfLayeredExitFadeRenderersMismatch(ActiveCustomer customer)
+    {
+        if (customer == null || !customer.usesLayeredCustomerSprites)
+        {
+            return;
+        }
+
+        bool bodyEnabled = customer.bodyRenderer != null && customer.bodyRenderer.enabled;
+        bool headEnabled = customer.headRenderer != null && customer.headRenderer.enabled;
+        if (bodyEnabled != headEnabled)
+        {
+            Debug.LogWarning(
+                "[CustomerFlowManager] Layered customer exit fade-out has mismatched Body/Head renderer states before completion.\n" +
+                $"Body renderer enabled: {GetRendererEnabledLabel(customer.bodyRenderer)}\n" +
+                $"Head renderer enabled: {GetRendererEnabledLabel(customer.headRenderer)}");
+        }
+
+        if (!bodyEnabled || !headEnabled)
+        {
+            Debug.LogWarning(
+                "[CustomerFlowManager] Layered customer renderer was disabled before exit fade-out completed.\n" +
+                $"Body renderer enabled: {GetRendererEnabledLabel(customer.bodyRenderer)}\n" +
+                $"Head renderer enabled: {GetRendererEnabledLabel(customer.headRenderer)}\n" +
+                $"Exit fade-out active: {customer.layeredExitFadeOutActive}\n" +
+                $"Exit fade-out completed: {customer.layeredExitFadeOutCompleted}");
+        }
+    }
+
+    private void WarnIfLayeredCustomerBodyHeadAlphaMismatch(ActiveCustomer customer, string context)
+    {
+        if (customer == null || !customer.usesLayeredCustomerSprites)
+        {
+            return;
+        }
+
+        if (AreLayeredCustomerBodyHeadAlphasEqual(customer))
+        {
+            return;
+        }
+
+        Debug.LogWarning(
+            "[CustomerFlowManager] Layered customer Body/Head alpha mismatch.\n" +
+            $"Context: {context}\n" +
+            $"Body alpha: {GetRendererAlphaLabel(customer.bodyRenderer)}\n" +
+            $"Head alpha: {GetRendererAlphaLabel(customer.headRenderer)}");
+    }
+
+    private static bool AreLayeredCustomerBodyHeadAlphasEqual(ActiveCustomer customer)
+    {
+        if (customer == null || customer.bodyRenderer == null || customer.headRenderer == null)
+        {
+            return true;
+        }
+
+        return Mathf.Abs(customer.bodyRenderer.color.a - customer.headRenderer.color.a) <= 0.001f;
+    }
+
+    private static string GetRendererAlphaLabel(SpriteRenderer renderer)
+    {
+        return renderer != null ? renderer.color.a.ToString("0.###") : "missing";
+    }
+
+    private void SetLayeredCustomerVisible(ActiveCustomer customer, bool visible, string reason)
+    {
+        if (customer == null || !customer.usesLayeredCustomerSprites)
+        {
+            return;
+        }
+
+        customer.layeredLastVisibilityReason = reason;
+        bool isExitRelatedHide = IsLayeredCustomerExitVisibilityContext(customer);
+        float distanceToExitHidePoint = GetPlanarDistance(customer.worldPosition, customer.exitSafeHidePoint);
+        if (!visible)
+        {
+            bool convertedToFadeOut = TryConvertLayeredCustomerExitHideToFadeOut(customer, reason);
+            if (convertedToFadeOut)
+            {
+                return;
+            }
+
+            bool blocked = ShouldBlockLayeredCustomerHide(customer, distanceToExitHidePoint);
+            if (isExitRelatedHide)
+            {
+                LogLayeredCustomerHideRequest(customer, true, reason, distanceToExitHidePoint, blocked);
+            }
+
+            if (blocked)
+            {
+                return;
+            }
+        }
+
+        SetLayeredCustomerRenderersEnabled(customer, visible);
+    }
+
+    private bool TryConvertLayeredCustomerExitHideToFadeOut(ActiveCustomer customer, string reason)
+    {
+        if (customer == null ||
+            !customer.usesLayeredCustomerSprites ||
+            !IsLayeredCustomerExitVisibilityContext(customer) ||
+            customer.layeredExitFadeOutCompleted)
+        {
+            return false;
+        }
+
+        LayeredExitFadeDecision decision = GetLayeredCustomerExitFadeDecision(customer);
+        if (decision.passedHardCutoff)
+        {
+            return false;
+        }
+
+        if (!decision.shouldStartFadeOut)
+        {
+            return false;
+        }
+
+        if (!customer.layeredExitFadeOutActive)
+        {
+            TryStartLayeredCustomerExitFadeOut(customer, reason + " / converted to exit fade-out", decision);
+        }
+
+        LogLayeredCustomerHideRequest(
+            customer,
+            true,
+            reason + " / kept visible until fade-out completes",
+            decision.distanceToExitHidePoint,
+            true);
+        return true;
+    }
+
+    private bool ShouldBlockLayeredCustomerHide(ActiveCustomer customer, float distanceToExitHidePoint)
+    {
+        if (customer == null || !customer.usesLayeredCustomerSprites)
+        {
+            return false;
+        }
+
+        if (!IsLayeredCustomerExitVisibilityContext(customer) || customer.layeredExitFadeOutCompleted)
+        {
+            return false;
+        }
+
+        return !GetLayeredCustomerExitFadeDecision(customer).passedHardCutoff;
+    }
+
+    private static bool IsLayeredCustomerExitVisibilityContext(ActiveCustomer customer)
+    {
+        return customer != null &&
+            customer.usesLayeredCustomerSprites &&
+            (customer.layeredIsExiting ||
+                customer.state == CustomerState.Leaving ||
+                customer.waitsForLayeredExitHide ||
+                customer.layeredExitHidePending ||
+                customer.layeredExitFadeOutActive ||
+                customer.layeredExitFadeOutStarted);
+    }
+
